<?xml version="1.0" encoding="UTF-8"?>
<model xmlns="http://www.alfresco.org/model/dictionary/1.0" name="datalink:database">
    <description>Modelo demo para prueba de concepto</description>
    <author>Venzia IT</author>
    <imports>
        <import uri="http://www.alfresco.org/model/dictionary/1.0" prefix="d"/>
    </imports>
    <namespaces>
        <namespace uri="http://www.datalink.venzia.es/model/content/1.0" prefix="datalink"/>
    </namespaces>
    <data-types/>
    <constraints/>
    <types/>
    <aspects>
        <aspect name="datalink:employee">
            <title>Employee</title>
            <description>Employee of company</description>
            <properties>
                <property name="datalink:last_name">
                    <title>Last Name</title>
                    <type>d:text</type>
                    <mandatory>true</mandatory>
                    <index enabled="true">
                        <tokenised>TRUE</tokenised>
                        <facetable>false</facetable>
                    </index>
                </property>
                <property name="datalink:hire_date">
                    <title>Hire Date</title>
                    <type>d:date</type>
                    <mandatory>true</mandatory>
                    <index enabled="true">
                        <tokenised>TRUE</tokenised>
                    </index>
                </property>
                <property name="datalink:first_name">
                    <title>First Name</title>
                    <type>d:text</type>
                    <mandatory>true</mandatory>
                    <index enabled="true">
                        <tokenised>TRUE</tokenised>
                        <facetable>false</facetable>
                    </index>
                </property>
                <property name="datalink:emp_no">
                    <title>No</title>
                    <type>d:int</type>
                    <mandatory>true</mandatory>
                    <index enabled="true">
                        <tokenised>TRUE</tokenised>
                    </index>
                </property>
            </properties>
            <associations/>
            <overrides/>
            <mandatory-aspects/>
        </aspect>
    </aspects>
</model>